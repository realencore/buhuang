# Cloudflare R2 image sync
# Copy this file to .env.local and fill in the real values.

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=linbuhuang-blog-images
# Optional. Fill this if Cloudflare shows a jurisdiction-specific S3 endpoint.
# Examples:
# R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_ENDPOINT=https://<ACCOUNT_ID>.eu.r2.cloudflarestorage.com
R2_ENDPOINT=
IMAGE_BASE_URL=https://img.linbuhuang.com

# Optional settings
IMAGE_PREFIX=blog
IMAGE_ATTACHMENT_DIRS=src/content/posts/_assets,src/content/posts/_attachments
IMAGE_MAX_WIDTH=2400
IMAGE_QUALITY=82
